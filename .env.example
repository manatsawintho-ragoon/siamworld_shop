# MySQL Database
# When using Docker: MYSQL_HOST=mysql, MYSQL_USER=siamworld (matches Docker compose)
# When using bare metal: MYSQL_HOST=127.0.0.1, MYSQL_USER=your_db_user
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=siamworld
MYSQL_PASSWORD=Change_Me_Strong_Password_123!
MYSQL_DATABASE=siamworld

# Redis
# When using Docker: REDIS_HOST=redis
# When using bare metal: REDIS_HOST=127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-key-min-32-chars
JWT_EXPIRES_IN=24h

# Encryption (for RCON passwords etc. - min 32 chars, MUST be different from JWT_SECRET)
ENCRYPTION_KEY=change-this-to-a-different-secret-min-32-chars

# Backend
BACKEND_PORT=4000
NODE_ENV=production

# Frontend — REQUIRED: replace YOUR_SERVER_IP with your server's public IP or domain
# Example: http://203.0.113.10:4000/api  or  https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:4000/api
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP:4000

# CORS — IMPORTANT for production security
# Set to your frontend URL to prevent other websites from calling your API
# Example: CORS_ORIGIN=https://shop.yourdomain.com
# Multiple origins: CORS_ORIGIN=https://shop.yourdomain.com,https://admin.yourdomain.com
# WARNING: leaving as * allows ANY website to call your API (dev only)
CORS_ORIGIN=*

# Rate Limiting (global: 300 req per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# EasySlip — Slip verification API (https://developer.easyslip.com)
EASYSLIP_API_KEY=94000d43-f783-4347-bd15-afe125854fd4
