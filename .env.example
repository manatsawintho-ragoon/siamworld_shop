# MySQL Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=siamworld
MYSQL_PASSWORD=Change_Me_Strong_Password_123!
MYSQL_DATABASE=siamworld

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-key-min-32-chars
JWT_EXPIRES_IN=24h

# Encryption (for RCON passwords etc. - min 32 chars, falls back to JWT_SECRET)
ENCRYPTION_KEY=change-this-to-a-different-secret-min-32-chars

# Backend
BACKEND_PORT=4000
NODE_ENV=production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
