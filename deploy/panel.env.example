# ============================================================
#  SiamWorld Panel — Environment Variables
#  Copy to panel.env and fill in values
# ============================================================

# Panel domain (without https://)
PANEL_DOMAIN=panel.siamsite.shop

# Source root (path to siamsite_shop directory on host)
SOURCE_ROOT=/path/to/siamsite_shop

# MySQL
PANEL_MYSQL_ROOT_PASSWORD=change_me_root_password
PANEL_MYSQL_PASSWORD=change_me_panel_password

# JWT Secret — REQUIRED, minimum 32 characters (generate: openssl rand -base64 48)
PANEL_JWT_SECRET=change_me_at_least_32_chars_long_secret

# Session duration (default: 24h). Increase only if needed.
PANEL_JWT_EXPIRES_IN=24h

# Allowed frontend origins (comma-separated). Use * for development only.
PANEL_CORS_ORIGIN=https://panel.siamsite.shop,http://localhost:3000

# Google OAuth — register callback at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback must go through Next.js proxy (panel domain), NOT api-panel subdomain
GOOGLE_CALLBACK_URL=https://panel.siamsite.shop/api/auth/google/callback

# Facebook OAuth — register callback at https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://panel.siamsite.shop/api/auth/facebook/callback

